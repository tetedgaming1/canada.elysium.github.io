{
  "name": "Citizen",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "description": "Minecraft username"
    },
    "town": {
      "type": "string",
      "description": "Name of the town they belong to"
    },
    "role": {
      "type": "string",
      "enum": [
        "leader",
        "councilor",
        "general",
        "builder",
        "diplomat",
        "citizen"
      ],
      "default": "citizen",
      "description": "Role in the nation"
    },
    "rank": {
      "type": "string",
      "description": "Custom rank or title"
    },
    "joined_date": {
      "type": "string",
      "format": "date",
      "description": "Date joined the nation"
    },
    "is_online": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string",
      "description": "Admin notes about this citizen"
    }
  },
  "required": [
    "username",
    "town"
  ]
}
